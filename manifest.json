{
  "manifest_version": 3,
  "name": "Smart translator",
  "version": "1.0.0",
  "description": "Chrome extension for translation, summarization, rewriting, explanation, grammar checking, and webpage assistance.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background/serviceWorker.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/contentScript.ts"]
    }
  ],

  "action": {
    "default_popup": "index.html"
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}